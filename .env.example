# ── Claude auth (choose one) ──────────────────────────────────────────────────
# Option A (recommended): paste a setup-token from `claude setup-token`
# Run `claude setup-token` on any machine where Claude Code is authenticated.
CLAUDE_SETUP_TOKEN=

# Option B: Anthropic API key (API billing — no Claude subscription needed)
# ANTHROPIC_API_KEY=sk-ant-...

# ── Claude model (optional) ───────────────────────────────────────────────────
# Default: claude-sonnet-4-6 — change only if you need a different model
# OA_CLAUDE_MODEL=claude-sonnet-4-6

# ── Telegram ──────────────────────────────────────────────────────────────────
OA_TELEGRAM_BOT_TOKEN=          # from @BotFather — see setup.sh for instructions
OA_TELEGRAM_ALLOWED_USERS=      # JSON array, e.g. ["alice","bob"]; empty = allow all

# ── WhatsApp (Baileys bridge) ─────────────────────────────────────────────────
# No token needed — WhatsApp is linked via QR code scan after first launch.
# The message the bot sends to acknowledge receipt (optional):
# BAILEYS_ACK_MESSAGE=received

# ── Webhook server ────────────────────────────────────────────────────────────
# Change only if the default ports are already in use on your machine.
# OA_WEBHOOK_PORT=8080
# OA_WEBHOOK_HOST=0.0.0.0
# BAILEYS_PORT=3100

# ── Optional: voice STT ───────────────────────────────────────────────────────
# At least one enables voice message transcription (Telegram/WhatsApp).
# Groq is the primary provider; OpenAI and Deepgram are fallbacks.
GROQ_API_KEY=
OPENAI_API_KEY=
DEEPGRAM_API_KEY=

# ── Optional: Perplexity (web search) ────────────────────────────────────────
PERPLEXITY_API_KEY=

# ── Advanced ──────────────────────────────────────────────────────────────────────────────
# Path to the gws binary — change only if gws is not on your PATH
# OA_GWS_BINARY=gws
