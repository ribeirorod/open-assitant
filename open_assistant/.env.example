# ── Claude ───────────────────────────────────────────────────────────────────
# Your Anthropic API key (required)
ANTHROPIC_API_KEY=sk-ant-...

# Model override (default: claude-sonnet-4-6)
# OA_CLAUDE_MODEL=claude-sonnet-4-6

# ── Telegram ─────────────────────────────────────────────────────────────────
# Bot token from @BotFather
OA_TELEGRAM_BOT_TOKEN=

# Comma-separated usernames allowed to interact (empty = allow all)
# OA_TELEGRAM_ALLOWED_USERS=["alice","bob"]

# ── WhatsApp (Meta Cloud API) ───────────────────────────────────────────────
# Webhook verification token (you choose this, must match Meta dashboard)
OA_WHATSAPP_VERIFY_TOKEN=

# Permanent access token from Meta developer dashboard
OA_WHATSAPP_ACCESS_TOKEN=

# Phone number ID from the WhatsApp Business Platform
OA_WHATSAPP_PHONE_NUMBER_ID=

# ── Webhook server ──────────────────────────────────────────────────────────
OA_WEBHOOK_HOST=0.0.0.0
OA_WEBHOOK_PORT=8080

# ── Google Workspace CLI ────────────────────────────────────────────────────
# Path to the gws binary (default: gws, assumes it's on PATH)
# OA_GWS_BINARY=gws
#
# Authenticate before first run:
#   gws auth login
# Or set a service-account key:
#   export GOOGLE_WORKSPACE_CLI_CREDENTIALS_FILE=/path/to/sa-key.json
