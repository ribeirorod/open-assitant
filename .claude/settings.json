{
  "permissions": {
    "allow": [
      "Read(/Users/beam/.open-assistant/memory/**)",
      "Write(/Users/beam/.open-assistant/memory/**)",
      "Read(/Users/beam/projects/**)",
      "Read(/Users/beam/Downloads/**)",
      "Read(/Users/beam/Documents/**)",
      "Bash(find /Users/beam/projects -iname *)",
      "Bash(find /Users/beam/Downloads -iname *)",
      "Bash(find /Users/beam/Documents -iname *)",
      "Bash(grep -ril * /Users/beam/projects)",
      "Bash(grep -ril * /Users/beam/Downloads)",
      "Bash(grep -ril * /Users/beam/Documents)"
